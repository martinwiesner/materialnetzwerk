# Backend environment (copy to .env OR change.env)

# Server
PORT=8081
NODE_ENV=development

# JWT (required)
# Use a long random string in real deployments.
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_SECRET_IN_PRODUCTION

# SQLite DB
DB_PATH=./data/material_library.db

# Uploads
UPLOAD_PATH=./uploads

# Optional: auto seed on start in development (non-destructive; seeds only when DB is empty)
SEED_ON_START=true

# Optional: demo login credentials for seed
DEMO_EMAIL=demo@local
DEMO_PASSWORD=demo
