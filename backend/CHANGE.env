# ============================================================
# Backend Environment
# Copy this to .env  OR  keep as CHANGE.env (both are supported)
# Real secrets → see backend/.env.secret (git-ignored)
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=8081
NODE_ENV=development

# ── Zitadel OIDC (REQUIRED) ──────────────────────────────────
# Domain of your Zitadel instance (without https://)
# Create a project + "User Agent" app in Zitadel, then paste the domain here.
# e.g.  your-org.eu1.zitadel.cloud  or  auth.yourdomain.com
ZITADEL_DOMAIN=your-instance.eu1.zitadel.cloud

# ── Database ─────────────────────────────────────────────────
DB_PATH=./data/material_library.db

# ── File Uploads ─────────────────────────────────────────────
UPLOAD_PATH=./uploads

# ── CORS / App URL ───────────────────────────────────────────
# Public URL of the frontend (CORS allow-list + outbound email links)
FRONTEND_URL=https://yourdomain.com
APP_URL=https://yourdomain.com

# ── Web Push / VAPID ─────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@yourdomain.com

# ── E-Mail via Brevo ─────────────────────────────────────────
BREVO_API_KEY=your-brevo-api-key
BREVO_FROM_EMAIL=no-reply@yourdomain.com
BREVO_FROM_NAME=Materialnetzwerk

# ── Development Seeds (optional) ─────────────────────────────
# Non-destructive: only seeds when the DB is empty
SEED_ON_START=true
DEMO_EMAIL=demo@local
DEMO_PASSWORD=demo
