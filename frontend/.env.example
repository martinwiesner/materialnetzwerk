# =========================================================
# Frontend Environment Variables
# Real secrets with pre-filled values → frontend/.env.local (git-ignored)
# =========================================================

# API URL
# In Docker: Leave empty — nginx proxies /api and /uploads automatically.
# In Dev (npm run dev): Set to your backend port.
# VITE_API_URL=http://localhost:8081
VITE_API_URL=

# ── Zitadel OIDC (REQUIRED) ──────────────────────────────────
# Authority: full URL of your Zitadel instance
# e.g.  https://your-org.eu1.zitadel.cloud
VITE_ZITADEL_AUTHORITY=https://your-instance.eu1.zitadel.cloud
# Client ID of the "User Agent" application you created in Zitadel
VITE_ZITADEL_CLIENT_ID=your-client-id-here
